    <!-- Tour steps -->
    <string name="tour_add_network_title">Hálózataid</string>
    <string name="tour_add_network_body">Szerver hozzáadásához koppints: +, vagy szerkessz itt meglévőket. A HexDroid alapból tartalmaz néhányat.</string>
    <string name="tour_connect_title">Kapcsolódás</string>
    <string name="tour_connect_body">Koppints a Kapcsolódás-ra a csatlakozáshoz. Több hálózathoz is kapcsolódhatsz egyidőben.</string>
    <string name="tour_switcher_title">Puffer lista</string>
    <string name="tour_switcher_body">Ez a panel listáz minden szervert, csatornát és megnyitott privát üzenetet. Húzd el, vagy koppints a ☰ gombra a megjelenítéshez. Koppints bármely elemre a váltáshoz</string>
    <string name="tour_send_title">Üzenetküldés</string>
    <string name="tour_send_body">Ide írva cseveghetsz. Perjeles parancsok is használhatók: /join #csatorna, /msg becenév szöveg, /part, /whois becenév, /me cselekvés szöveg, stb.</string>
    <string name="tour_more_title">További műveletek</string>
    <string name="tour_more_body">Ebben a menüben érhető el a csatornalista, fájlátvitelek, mellőzési lista, hálózati beállítások és egyebek. Emellett csatonamódokat és topikkezelést is tartalmaz, ha Op vagy.</string>
    <string name="tour_settings_title">Megjelenés &amp; beállítások</string>
    <string name="tour_settings_body">Válassz témát, állítsd be a betűméretet, értesítési hangokat, adatvédelmi lehetőségeket és még sok egyebet. A módosítások azonnaliak.</string>
    <string name="tour_dcc_title">Fájlátvitelek (DCC)</string>
    <string name="tour_dcc_body">Közvetlenül DCC segítségével küldhetők és fogadhatók fájlok felhasználók között. Router mögül, a Passzív DCC nyújthat megoldást port-továbbítási gondokra. Az SDCC szintén támogatott.</string>
    <string name="tour_send_file_title">Fájlküldés</string>
    <string name="tour_send_file_body">Add meg a címzett becenevét, majd válassz fájt a tárhelyről. A bejövő DCC kérések is ide érkeznek, melyeket értesítésekből elfogadhatsz, vagy elutasíthatsz.</string>
    <string name="tour_support_title">További segítség</string>
    <string name="tour_support_body">Támogatásért, javaslatokhoz, vagy csak csevegni a többi HexDroid felhasználóval, kapcsolódj az AfterNET szerverhez és lépj be a #HexDroid csatornára.</string>
    <string name="tour_support_fallback">Az AfterNET még nincs a listádon: támogatásért koppints az AfterNET hozzáadására, majd kapcsolódj és lépj be a #HexDroid csatornára.</string>
    <string name="tour_support_action">AfterNET hozzáadása</string>
    <string name="tour_replay_title">Bemutató újrakezdése</string>
    <string name="tour_replay_body">Az áttekintést bármikor újrakezdheted innen: Beállítások - Névjegy. Befejezéshez koppints erre: Kész</string>

