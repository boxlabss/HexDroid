    <string name="tour_add_network_title">Vos réseaux</string>
    <string name="tour_add_network_body">Appuyez sur + pour ajouter un serveur ou modifier les existants. HexDroid inclut quelques serveurs par défaut — Libera, Freenode et AfterNET.</string>
    <string name="tour_connect_title">Connexion</string>
    <string name="tour_connect_body">Appuyez sur Connexion pour vous connecter. Le bouton devient vert en ligne. Plusieurs réseaux simultanément sont possibles.</string>
    <string name="tour_settings_title">Apparence et paramètres</string>
    <string name="tour_settings_body">Choisissez un thème, ajustez la taille de la police et les notifications. Les changements s\'appliquent instantanément.</string>
    <string name="tour_switcher_title">Liste des tampons</string>
    <string name="tour_switcher_body">Ce panneau liste tous vos serveurs, canaux et messages privés ouverts. Balayez ou appuyez sur ☰ pour l\'afficher.</string>
    <string name="tour_more_title">Plus d\'actions</string>
    <string name="tour_more_body">Ce menu donne accès à la liste des canaux, transferts de fichiers, liste d\'ignorés, paramètres réseau et plus.</string>
    <string name="tour_send_title">Envoyer des messages</string>
    <string name="tour_send_body">Tapez ici pour chatter. Les commandes slash fonctionnent aussi : /join #canal, /msg pseudo texte, /part, /whois pseudo.</string>
    <string name="tour_dcc_title">Transferts de fichiers (DCC)</string>
    <string name="tour_dcc_body">Activez DCC pour envoyer et recevoir des fichiers directement entre utilisateurs. Le DCC passif évite les problèmes NAT.</string>
    <string name="tour_send_file_title">Envoyer un fichier</string>
    <string name="tour_send_file_body">Entrez le pseudo cible puis choisissez un fichier. Les offres DCC entrantes apparaissent également ici.</string>
    <string name="tour_support_title">Besoin d\'aide ?</string>
    <string name="tour_support_body">Connectez-vous à AfterNET et rejoignez #HexDroid pour du support ou pour discuter avec d\'autres utilisateurs.</string>
    <string name="tour_support_fallback">AfterNET n\'est pas dans votre liste — appuyez sur Ajouter AfterNET puis rejoignez #HexDroid.</string>
    <string name="tour_support_action">Ajouter AfterNET</string>
    <string name="tour_replay_title">Rejouer ce tour</string>
    <string name="tour_replay_body">Vous pouvez relancer le tutoriel depuis Paramètres → À propos. Appuyez sur Terminé pour finir.</string>

