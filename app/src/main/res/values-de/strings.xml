    <string name="tour_add_network_title">Netzwerk hinzufügen</string>
    <string name="tour_add_network_body">Tippe auf + um ein neues Netzwerk hinzuzufügen oder ein bestehendes zu bearbeiten. HexDroid hat einige Standardnetzwerke vorinstalliert.</string>
    <string name="tour_connect_title">Verbinden</string>
    <string name="tour_connect_body">Verbinde dich mit dem ausgewählten Netzwerk. Nach der Verbindung kannst du Kanäle beitreten und chatten.</string>
    <string name="tour_settings_title">Einstellungen</string>
    <string name="tour_settings_body">Passe Darstellung, Schriften und andere Einstellungen hier an.</string>
    <string name="tour_switcher_title">Umschalter</string>
    <string name="tour_switcher_body">Diese Seitenleiste zeigt deinen Server, Kanäle und Privatnachrichten. Tippe zum Wechseln.</string>
    <string name="tour_more_title">Weitere Aktionen</string>
    <string name="tour_more_body">Dieses Menü enthält Kanalliste, Dateiübertragungen, Einstellungen, Netzwerke und mehr.</string>
    <string name="tour_send_title">Nachrichten senden</string>
    <string name="tour_send_body">Hier tippen zum Chatten. Du kannst auch Befehle wie /join #kanal, /msg nick hallo, /whois nick usw. verwenden.</string>
    <string name="tour_dcc_title">DCC aktivieren</string>
    <string name="tour_dcc_body">Aktiviere DCC zum Senden/Empfangen von Dateien. Hinter NAT kann der Passiv-Modus helfen.</string>
    <string name="tour_send_file_title">Datei senden</string>
    <string name="tour_send_file_body">Gib einen Ziel-Nick ein und wähle eine Datei. (DCC muss aktiviert sein.) Eingehende Angebote erscheinen ebenfalls hier.</string>
    <string name="tour_support_title">Hilfe benötigt?</string>
    <string name="tour_support_body">Du kannst dich hier verbinden für Support in #HexDroid.</string>
    <string name="tour_support_fallback">Wenn du AfterNET nicht in deiner Liste siehst, tippe auf AfterNET hinzufügen (oder +). Verbinde dich dort für Support in #HexDroid.</string>
    <string name="tour_support_action">AfterNET hinzufügen</string>
    <string name="tour_replay_title">Tour wiederholen</string>
    <string name="tour_replay_body">Du kannst die Tour jederzeit in den Einstellungen wiederholen.</string>

